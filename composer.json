{
    "name": "cbsnorthstar/onlineordering",
    "description": "online ordering",
    "type": "project",
    "autoload": {
        "psr-4": {
            "CBSNorthStar\\": "inc/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CBSNorthStar\\Tests\\": "tests/unit/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "require": {
        "htmlburger/carbon-fields": "^3.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "brain/monkey": "^2.7",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit"
    }
}
